{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/simulate", "dest": "/api/simulate.py" },
    { "src": "/api/defaults", "dest": "/api/defaults.py" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
